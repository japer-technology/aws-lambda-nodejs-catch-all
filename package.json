{
  "name": "aws-lambda-nodejs-catch-all",
  "version": "1.0.0",
  "description": "A universal Node.js handler that captures and routes AWS Lambda events.",
  "main": "index.mjs",
  "bin": {
    "invoke": "bin/invoke.js"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "package": "npm pack",
    "invoke": "node bin/invoke.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "aws",
    "lambda",
    "events",
    "serverless"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "typescript": "7.0.2"
  },
  "files": [
    "index.mjs",
    "dispatcher.js",
    "dispatch-config.js",
    "handlers",
    "logger.js",
    "collectInvocation.js",
    "index.d.ts"
  ],
  "types": "index.d.ts"
}
